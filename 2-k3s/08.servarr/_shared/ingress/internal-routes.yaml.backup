---
# Internal LAN-only IngressRoutes (*.epavli domains via Pi-hole DNS)
# All route to Traefik at 192.168.10.101
# TLS certificates managed by cert-manager (self-signed CA for internal use)

# Sonarr - TV Shows
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: sonarr-internal
  namespace: servarr
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(`sonarr.epavli`)
      kind: Rule
      services:
        - name: sonarr
          port: 8989
  tls:
    secretName: epavli-tls
---
# Sonarr2 - Anime
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: sonarr2-internal
  namespace: servarr
spec:
